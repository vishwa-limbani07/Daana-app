# Copy this file to .env and fill in real values. NEVER commit .env.
# Run: cp .env.example .env

# --- Server ---
# Avoid port 5000 — macOS AirPlay Receiver binds to it and returns 403.
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database ---
# Get a free cluster from https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/crowdfund?retryWrites=true&w=majority

# --- JWT ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Razorpay ---
# Get test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret is set when you create a webhook in Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Cloudinary (for campaign images) ---
# Free account: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Email (Nodemailer with Gmail) ---
# Use an App Password, not your Gmail password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_16_character_app_password
EMAIL_FROM="CrowdFund <noreply@crowdfund.com>"
